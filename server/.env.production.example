# ── Production environment variables ─────────────────────────────────────
# Copy this to server/.env and fill in your values
# NEVER commit the actual .env file to git

# Server
PORT=10000
NODE_ENV=production

# MongoDB Atlas connection string
# Get this from https://cloud.mongodb.com → your cluster → Connect
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/crowd_faq?retryWrites=true&w=majority

# JWT — use a long random string (min 32 chars)
JWT_SECRET=<generate with: openssl rand -hex 32>
JWT_EXPIRES_IN=7d

# Frontend URL (set this after deploying the frontend)
CLIENT_URL=https://your-frontend.onrender.com

# ── LLM Provider ────────────────────────────────────────────────────────────
# Option A: OpenAI (easiest, works on Render immediately)
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...                            # from https://platform.openai.com/api-keys
LLM_MODEL=gpt-4o-mini                            # fast + cheap, sufficient for FAQ generation

# Option B: Anthropic (higher quality)
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-3-haiku-20240307

# Option C: Ollama (self-hosted, only works locally with GPU)
# LLM_PROVIDER=ollama
# LLM_MODEL=qwen2.5:3b
# OLLAMA_BASE_URL=http://localhost:11434
# EMBED_MODEL=nomic-embed-text